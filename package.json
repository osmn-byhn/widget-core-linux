{
  "name": "@osmn-byhn/widget-core-linux",
  "version": "1.0.0",
  "description": "High-performance desktop widget manager library for Linux.",
  "author": "Osman Beyhan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osmn-byhn/widget-core-linux.git"
  },
  "bugs": {
    "url": "https://github.com/osmn-byhn/widget-core-linux/issues"
  },
  "homepage": "https://widget-core-linux.osmanbeyhan.com",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "setup": "./scripts/setup-linux.sh",
    "preinstall": "./scripts/setup-linux.sh",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "install": "node-gyp rebuild",
    "demo": "WEBKIT_DISABLE_ACCELERATED_COMPOSITING=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 GDK_BACKEND=x11 node examples/demo-widget.js"
  },
  "keywords": [
    "widget",
    "desktop",
    "linux",
    "gtk",
    "gui",
    "webkit",
    "electron-alternative"
  ],
  "files": [
    "dist",
    "native",
    "binding.gyp",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gypfile": true,
  "devDependencies": {
    "@types/node": "^25.5.0",
    "node-addon-api": "^8.7.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}